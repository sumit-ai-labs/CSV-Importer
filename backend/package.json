{
  "name": "groweasy-csv-importer-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend service for GrowEasy AI CSV Importer",
  "main": "build/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx --env-file=.env --watch src/server.ts",
    "start": "node --env-file=.env build/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:coverage": "jest --config jest.config.ts --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.52.7",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
